#!/bin/bash

#GLOBALS
DOCUMENT_TEMPLATE=~/dotfiles/typst/templates/write_up.typ
CURRENT_DIR=$PWD

# If first argument is a known typst command, pass it through to the real typst binary
case "$1" in
    watch|compile|fonts|help|query|update|--version)
        exec /usr/bin/typst "$@"
        ;;
esac

SEARCH_QUERY=$(fd -i -tf -etyp . ~ 2>/dev/null | \
  fzf \
  --expect=ctrl-n \
  --footer="[ENTER] Open | [CTRL-N] Force New | [ESC] Exit.
Current Path: $CURRENT_DIR.
You can edit this script at ~/dotfiles/bin/typst." \
  --print-query \
  --layout=reverse \
  --info=inline \
  --padding=1,2 
)

{ read -r QUERY; read -r KEY; read -r TYP_FILE_PATH; } <<< "$SEARCH_QUERY"

# 1. ESC / CANCEL CHECK
if [[ -z "$QUERY" ]] && [[ -z "$TYP_FILE_PATH" ]]; then
  exit 0
fi

# 2. FILE CREATION ROUTINE
# Trigger if no file found, OR if you explicitly forced a new file with CTRL-N
if [[ -z "$TYP_FILE_PATH" ]] || [[ "$KEY" == "ctrl-n" ]]; then
  
  # Failsafe: If you hit CTRL-N but didn't type anything yet
  if [[ -z "$QUERY" ]]; then
      read -p "Enter the new file name: " QUERY
      if [[ -z "$QUERY" ]]; then exit 0; fi
  fi

  read -p "File not found. Create ${QUERY}.typ at ${CURRENT_DIR}? [Y/n]: " USE_CURRENT_DIR_RESPONSE

  if [[ -z "$USE_CURRENT_DIR_RESPONSE" || "$USE_CURRENT_DIR_RESPONSE" == [yY] ]]; then 
    TYP_FILE_PATH="${CURRENT_DIR}/${QUERY}.typ"
    sed "s|{{TITLE}}|$QUERY|g" "$DOCUMENT_TEMPLATE" > "$TYP_FILE_PATH"
  else
    # --- SECONDARY DIRECTORY PICKER ---
    echo "Select a directory for ${QUERY}.typ..."
    sleep 1

    SELECTED_DIR=$(fd -t d . ~ 2>/dev/null | \
      fzf \
      --prompt="Target Directory > " \
      --layout=reverse \
      --info=inline)

    if [[ -z "$SELECTED_DIR" ]]; then
        echo "Canceled."
        exit 0
    fi

    TYP_FILE_PATH="${SELECTED_DIR}/${QUERY}.typ"
    sed "s|{{TITLE}}|$QUERY|g" "$DOCUMENT_TEMPLATE" > "$TYP_FILE_PATH"
  fi
fi

# Open files
PDF_PATH="${TYP_FILE_PATH%.typ}.pdf"

# open pdf via typst watcher
/usr/bin/typst watch "$TYP_FILE_PATH" --open /usr/bin/sioyek &> /dev/null &
TYPST_PID=$!

# open nvim 
nvim "$TYP_FILE_PATH"

# cleanup 
kill $TYPST_PID 2> /dev/null
pkill -f "sioyek.*$PDF_PATH" 2> /dev/null
